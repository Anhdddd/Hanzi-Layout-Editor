{
  "version": 1,
  "pageSize": "A4",
  "name": "Stroke Order Focus",
  "description": "Tập trung vào thứ tự nét viết với stroke progression SVG lớn và lưới 米字格.",
  "elements": [
    {
      "id": "tpl_so_title",
      "type": "text",
      "x": 10,
      "y": 10,
      "width": 190,
      "height": 10,
      "rotation": 0,
      "zIndex": 1,
      "locked": false,
      "content": "Luyện viết: {{character}}  /{{pinyin}}/  {{meaning_vi}}",
      "fontSize": 14,
      "fontFamily": "LXGW WenKai",
      "fontWeight": "bold",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#1a1a1a",
      "backgroundColor": "transparent",
      "textAlign": "left",
      "lineHeight": 1.4
    },
    {
      "id": "tpl_so_mainchar",
      "type": "hanziText",
      "x": 10,
      "y": 24,
      "width": 40,
      "height": 40,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "content": "{{character}}",
      "charSize": 48,
      "charGap": 0,
      "color": "#000000",
      "lineHeight": 1
    },
    {
      "id": "tpl_so_progression",
      "type": "strokeProgression",
      "x": 55,
      "y": 24,
      "width": 140,
      "height": 40,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "character": "{{character}}",
      "stepSize": 22,
      "stepGap": 1,
      "completedColor": "#000000",
      "activeColor": "#cc0000",
      "showStepNumbers": true,
      "numberFontSize": 7,
      "numberColor": "#888888",
      "showFullCharFirst": false,
      "fullCharColor": "#000000"
    },
    {
      "id": "tpl_so_divider1",
      "type": "divider",
      "x": 10,
      "y": 68,
      "width": 190,
      "height": 8,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "label": "Tập viết theo 米字格",
      "lineColor": "#cccccc",
      "lineWidth": 1,
      "lineStyle": "dashed",
      "ornament": "diamond",
      "fontSize": 8,
      "color": "#666666"
    },
    {
      "id": "tpl_so_migrid",
      "type": "miGrid",
      "x": 10,
      "y": 80,
      "width": 190,
      "height": 100,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "rows": 6,
      "cols": 12,
      "cellSize": 15,
      "borderColor": "#b0b0b0",
      "borderWidth": 1,
      "showCrossLines": true,
      "showDiagonalLines": true,
      "guideCharacter": "{{character}}",
      "guideOpacity": 0.12,
      "guideFillRows": 2,
      "guideFontSize": 28
    },
    {
      "id": "tpl_so_divider2",
      "type": "divider",
      "x": 10,
      "y": 178,
      "width": 190,
      "height": 8,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "label": "Viết tự do",
      "lineColor": "#cccccc",
      "lineWidth": 1,
      "lineStyle": "dashed",
      "ornament": "dot",
      "fontSize": 8,
      "color": "#666666"
    },
    {
      "id": "tpl_so_freegrid",
      "type": "miGrid",
      "x": 10,
      "y": 190,
      "width": 190,
      "height": 90,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "rows": 6,
      "cols": 12,
      "cellSize": 15,
      "borderColor": "#d0d0d0",
      "borderWidth": 1,
      "showCrossLines": true,
      "showDiagonalLines": true,
      "guideCharacter": "",
      "guideOpacity": 0.1,
      "guideFillRows": 0,
      "guideFontSize": 28
    }
  ]
}
