{
  "version": 1,
  "pageSize": "A4",
  "name": "Elegant Hanzi Workbook Template",
  "description": "One Hanzi item per printable A4 page.",
  "elements": [
    {
      "id": "tpl_bg_card",
      "type": "shape",
      "x": 8,
      "y": 8,
      "width": 194,
      "height": 281,
      "rotation": 0,
      "zIndex": 0,
      "locked": false,
      "shapeType": "roundedRect",
      "borderColor": "#e7dcc8",
      "borderWidth": 1,
      "backgroundColor": "#fffdf8",
      "borderStyle": "solid",
      "borderRadiusTL": 18,
      "borderRadiusTR": 18,
      "borderRadiusBR": 18,
      "borderRadiusBL": 18
    },
    {
      "id": "tpl_top_rule",
      "type": "divider",
      "x": 18,
      "y": 16,
      "width": 174,
      "height": 12,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "label": "HSK {{hsk_level}} · Bài {{_index}}",
      "lineColor": "#b08d57",
      "lineWidth": 1,
      "lineStyle": "solid",
      "ornament": "hanzi",
      "fontSize": 9,
      "color": "#805d2e"
    },
    {
      "id": "tpl_main_character",
      "type": "text",
      "x": 18,
      "y": 30,
      "width": 58,
      "height": 58,
      "rotation": 0,
      "zIndex": 3,
      "locked": false,
      "content": "{{character}}",
      "fontSize": 92,
      "fontFamily": "Noto Serif SC",
      "fontWeight": "900",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#111827",
      "backgroundColor": "transparent",
      "textAlign": "center",
      "lineHeight": 1
    },
    {
      "id": "tpl_title",
      "type": "text",
      "x": 82,
      "y": 34,
      "width": 105,
      "height": 16,
      "rotation": 0,
      "zIndex": 3,
      "locked": false,
      "content": "{{pinyin}} · {{han_viet}}",
      "fontSize": 24,
      "fontFamily": "Noto Sans SC",
      "fontWeight": "700",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#8a3b12",
      "backgroundColor": "transparent",
      "textAlign": "left",
      "lineHeight": 1.2
    },
    {
      "id": "tpl_meaning",
      "type": "callout",
      "x": 82,
      "y": 54,
      "width": 105,
      "height": 34,
      "rotation": 0,
      "zIndex": 3,
      "locked": false,
      "title": "Nghĩa",
      "body": "{{meaning_vi}}\nEN: {{meaning_en}}",
      "icon": "✦",
      "accentColor": "#c2410c",
      "backgroundColor": "#fff7ed",
      "borderColor": "#fed7aa",
      "fontSize": 10,
      "fontFamily": "Noto Sans SC",
      "color": "#432818",
      "borderRadius": 14
    },
    {
      "id": "tpl_meta",
      "type": "table",
      "x": 18,
      "y": 96,
      "width": 174,
      "height": 26,
      "rotation": 0,
      "zIndex": 3,
      "locked": false,
      "tableRows": 2,
      "tableCols": 4,
      "tableData": [
        ["Bộ thủ", "Số nét", "Cấu tạo", "Ví dụ"],
        ["{{radical}}", "{{stroke_count}}", "{{stroke_decomposition}}", "{{example_word}} · {{example_pinyin}}"]
      ],
      "headerBg": "#f8ecd9",
      "borderColor": "#d6b98c",
      "cellPadding": 1.8,
      "fontSize": 9,
      "fontFamily": "Noto Sans SC",
      "fontColor": "#2f241b",
      "cellBg": "#fffaf0",
      "autoHeight": false
    },
    {
      "id": "tpl_stroke",
      "type": "callout",
      "x": 18,
      "y": 130,
      "width": 174,
      "height": 28,
      "rotation": 0,
      "zIndex": 3,
      "locked": false,
      "title": "Thứ tự nét",
      "body": "{{stroke_progression}}",
      "icon": "筆",
      "accentColor": "#2563eb",
      "backgroundColor": "#eff6ff",
      "borderColor": "#bfdbfe",
      "fontSize": 10,
      "fontFamily": "Noto Sans SC",
      "color": "#172554",
      "borderRadius": 12
    },
    {
      "id": "tpl_practice_title",
      "type": "divider",
      "x": 18,
      "y": 166,
      "width": 174,
      "height": 10,
      "rotation": 0,
      "zIndex": 3,
      "locked": false,
      "label": "Tập viết",
      "lineColor": "#d6b98c",
      "lineWidth": 1,
      "lineStyle": "dashed",
      "ornament": "diamond",
      "fontSize": 9,
      "color": "#805d2e"
    },
    {
      "id": "tpl_grid_main",
      "type": "practiceGrid",
      "x": 22,
      "y": 183,
      "width": 166,
      "height": 62,
      "rotation": 0,
      "zIndex": 3,
      "locked": false,
      "rows": 4,
      "cols": 12,
      "cellSize": 13,
      "borderColor": "#b7a17d",
      "borderWidth": 1,
      "showCrossLines": true,
      "guideCharacter": "{{character}}",
      "guideOpacity": 0.13,
      "guideFillRows": 1,
      "guideFontSize": 28
    },
    {
      "id": "tpl_checklist",
      "type": "checklist",
      "x": 18,
      "y": 252,
      "width": 84,
      "height": 30,
      "rotation": 0,
      "zIndex": 3,
      "locked": false,
      "title": "Tự kiểm tra",
      "items": "Đọc đúng {{pinyin}}\nNhớ nghĩa: {{meaning_vi}}\nViết đủ {{stroke_count}} nét",
      "boxStyle": "square",
      "checkedSymbol": "",
      "borderColor": "#e7dcc8",
      "accentColor": "#c2410c",
      "fontSize": 8,
      "fontFamily": "Noto Sans SC",
      "color": "#2f241b",
      "lineGap": 1.2
    },
    {
      "id": "tpl_example",
      "type": "callout",
      "x": 108,
      "y": 252,
      "width": 84,
      "height": 30,
      "rotation": 0,
      "zIndex": 3,
      "locked": false,
      "title": "Ví dụ",
      "body": "{{example_word}} · {{example_pinyin}}\n{{example_meaning}}",
      "icon": "例",
      "accentColor": "#16a34a",
      "backgroundColor": "#f0fdf4",
      "borderColor": "#bbf7d0",
      "fontSize": 8,
      "fontFamily": "Noto Sans SC",
      "color": "#14532d",
      "borderRadius": 12
    }
  ]
}