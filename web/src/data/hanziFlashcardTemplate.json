{
  "version": 1,
  "pageSize": "A4",
  "name": "Flashcard Style",
  "description": "2 chữ/trang: SVG chữ, stroke progression và lưới luyện viết.",
  "recommendedItemsPerPage": 2,
  "elements": [
    {
      "id": "flash_bg",
      "type": "shape",
      "x": 10,
      "y": 6,
      "width": 190,
      "height": 132,
      "rotation": 0,
      "zIndex": 0,
      "locked": false,
      "shapeType": "roundedRect",
      "borderColor": "#1d4ed8",
      "borderWidth": 2,
      "backgroundColor": "#eff6ff",
      "borderStyle": "solid",
      "borderRadiusTL": 16,
      "borderRadiusTR": 16,
      "borderRadiusBR": 16,
      "borderRadiusBL": 16
    },
    {
      "id": "flash_hanzi",
      "type": "hanziText",
      "x": 16,
      "y": 10,
      "width": 36,
      "height": 36,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "content": "{{character}}",
      "charSize": 42,
      "charGap": 0,
      "color": "#1e3a8a",
      "lineHeight": 1
    },
    {
      "id": "flash_info",
      "type": "text",
      "x": 56,
      "y": 12,
      "width": 138,
      "height": 8,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
