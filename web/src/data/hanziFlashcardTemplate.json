{
  "version": 1,
  "pageSize": "A4",
  "name": "Flashcard Style Template",
  "description": "Bold card-like layout, good for vocabulary review.",
  "recommendedItemsPerPage": 2,
  "elements": [
    {
      "id": "flash_bg",
      "type": "shape",
      "x": 18,
      "y": 18,
      "width": 174,
      "height": 120,
      "rotation": 0,
      "zIndex": 0,
      "locked": false,
      "shapeType": "roundedRect",
      "borderColor": "#1d4ed8",
      "borderWidth": 2,
      "backgroundColor": "#eff6ff",
      "borderStyle": "solid",
      "borderRadiusTL": 22,
      "borderRadiusTR": 22,
      "borderRadiusBR": 22,
      "borderRadiusBL": 22
    },
    {
      "id": "flash_hanzi",
      "type": "text",
      "x": 24,
      "y": 24,
      "width": 70,
      "height": 72,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "content": "{{character}}",
      "fontSize": 104,
      "fontFamily": "Noto Serif SC",
      "fontWeight": "900",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#1e3a8a",
      "backgroundColor": "transparent",
      "textAlign": "center",
      "lineHeight": 1
    },
    {
      "id": "flash_info",
      "type": "callout",
      "x": 100,
      "y": 28,
      "width": 82,
      "height": 52,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "title": "{{pinyin}} · {{han_viet}}",
      "body": "{{meaning_vi}}\n{{meaning_en}}",
      "icon": "音",
      "accentColor": "#1d4ed8",
      "backgroundColor": "#ffffff",
      "borderColor": "#bfdbfe",
      "fontSize": 11,
      "fontFamily": "Noto Sans SC",
      "color": "#1e3a8a",
      "borderRadius": 14
    },
    {
      "id": "flash_example",
      "type": "text",
      "x": 100,
      "y": 86,
      "width": 82,
      "height": 14,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "content": "{{example_word}} · {{example_meaning}}",
      "fontSize": 12,
      "fontFamily": "Noto Sans SC",
      "fontWeight": "700",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#172554",
      "backgroundColor": "transparent",
      "textAlign": "left",
      "lineHeight": 1.2
    },
    {
      "id": "flash_grid",
      "type": "practiceGrid",
      "x": 24,
      "y": 104,
      "width": 158,
      "height": 26,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "rows": 2,
      "cols": 12,
      "cellSize": 11.5,
      "borderColor": "#60a5fa",
      "borderWidth": 1,
      "showCrossLines": true,
      "guideCharacter": "{{character}}",
      "guideOpacity": 0.1,
      "guideFillRows": 1,
      "guideFontSize": 24
    }
  ]
}