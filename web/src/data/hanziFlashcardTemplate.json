      "fontFamily": "LXGW WenKai",
      "fontWeight": "700",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#1d4ed8",
      "backgroundColor": "transparent",
      "textAlign": "left",
      "lineHeight": 1.2
    },
    {
      "id": "flash_stroke",
      "type": "strokeProgression",
      "x": 56,
      "y": 22,
      "width": 138,
      "height": 22,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "character": "{{character}}",
      "stepSize": 16,
      "stepGap": 0.5,
      "completedColor": "#1e3a8a",
      "activeColor": "#dc2626",
      "showStepNumbers": true,
      "numberFontSize": 6,
      "numberColor": "#6b7280",
      "showFullCharFirst": false,
      "fullCharColor": "#1e3a8a"
    },
    {
      "id": "flash_meaning",
      "type": "text",
      "x": 16,
      "y": 46,
      "width": 178,
      "height": 6,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "content": "EN: {{meaning_en}}",
      "fontSize": 8,
      "fontFamily": "LXGW WenKai",
      "fontWeight": "normal",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#475569",
      "backgroundColor": "transparent",
      "textAlign": "left",
      "lineHeight": 1.2
    },
    {
      "id": "flash_grid",
      "type": "practiceGrid",
      "x": 16,
      "y": 54,
      "width": 178,
      "height": 80,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "rows": 6,
      "cols": 14,
      "cellSize": 12,
