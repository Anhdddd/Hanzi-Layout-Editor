      "stepGap": 0.5,
      "completedColor": "#333333",
      "activeColor": "#e11d48",
      "showStepNumbers": false,
      "numberFontSize": 7,
      "numberColor": "#999999",
      "showFullCharFirst": false,
      "fullCharColor": "#000000"
    },
    {
      "id": "tpl_cd_char1_grid",
      "type": "practiceGrid",
      "x": 10,
      "y": 52,
      "width": 190,
      "height": 80,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "rows": 5,
      "cols": 14,
      "cellSize": 13,
      "borderColor": "#aaaaaa",
      "borderWidth": 1,
      "showCrossLines": true,
      "guideCharacter": "{{character}}",
      "guideOpacity": 0.12,
      "guideFillRows": 1,
      "guideFontSize": 26
    },
    {
      "id": "tpl_cd_separator",
      "type": "divider",
      "x": 10,
      "y": 140,
      "width": 190,
      "height": 8,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "label": "",
      "lineColor": "#dddddd",
      "lineWidth": 1,
      "lineStyle": "solid",
      "ornament": "none",
      "fontSize": 8,
      "color": "#999999"
    }
