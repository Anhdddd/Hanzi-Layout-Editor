{
  "version": 1,
  "pageSize": "A4",
  "name": "Compact Dual Character",
  "description": "2 chữ mỗi trang, bố cục gọn gàng với stroke progression và lưới 田字格.",
  "elements": [
    {
      "id": "tpl_cd_char1_title",
      "type": "text",
      "x": 10,
      "y": 8,
      "width": 190,
      "height": 8,
      "rotation": 0,
      "zIndex": 1,
      "locked": false,
      "content": "{{character}}  /{{pinyin}}/  —  {{meaning_vi}}",
      "fontSize": 12,
      "fontFamily": "LXGW WenKai",
      "fontWeight": "bold",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#222222",
      "backgroundColor": "transparent",
      "textAlign": "left",
      "lineHeight": 1.3
    },
    {
      "id": "tpl_cd_char1_svg",
      "type": "hanziText",
      "x": 10,
      "y": 18,
      "width": 30,
      "height": 30,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "content": "{{character}}",
      "charSize": 36,
      "charGap": 0,
      "color": "#000000",
      "lineHeight": 1
    },
    {
      "id": "tpl_cd_char1_strokes",
      "type": "strokeProgression",
      "x": 44,
      "y": 18,
      "width": 156,
      "height": 30,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "character": "{{character}}",
