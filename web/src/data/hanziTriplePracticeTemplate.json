{
  "version": 1,
  "pageSize": "A4",
  "name": "Triple Practice Template",
  "description": "Compact one-item slot designed for Items/page = 3.",
  "recommendedItemsPerPage": 3,
  "elements": [
    {
      "id": "triple_card",
      "type": "shape",
      "x": 14,
      "y": 12,
      "width": 182,
      "height": 82,
      "rotation": 0,
      "zIndex": 0,
      "locked": false,
      "shapeType": "roundedRect",
      "borderColor": "#d6c3a5",
      "borderWidth": 1,
      "backgroundColor": "#fffdf7",
      "borderStyle": "solid",
      "borderRadiusTL": 16,
      "borderRadiusTR": 16,
      "borderRadiusBR": 16,
      "borderRadiusBL": 16
    },
    {
      "id": "triple_char",
      "type": "text",
      "x": 22,
      "y": 18,
      "width": 36,
      "height": 34,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "content": "{{character}}",
      "fontSize": 54,
      "fontFamily": "Noto Serif SC",
      "fontWeight": "900",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#111827",
      "backgroundColor": "transparent",
      "textAlign": "center",
      "lineHeight": 1
    },
    {
      "id": "triple_info",
      "type": "callout",
      "x": 64,
      "y": 18,
      "width": 124,
      "height": 28,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "title": "{{pinyin}} · {{han_viet}}",
      "body": "{{meaning_vi}} · {{example_word}} ({{example_pinyin}})",
      "icon": "字",
      "accentColor": "#b45309",
      "backgroundColor": "#fffbeb",
      "borderColor": "#fde68a",
      "fontSize": 8,
      "fontFamily": "Noto Sans SC",
      "color": "#3f2a12",
      "borderRadius": 10
    },
    {
      "id": "triple_grid",
      "type": "practiceGrid",
      "x": 22,
      "y": 56,
      "width": 166,
      "height": 26,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "rows": 2,
      "cols": 14,
      "cellSize": 10.8,
      "borderColor": "#b7a17d",
      "borderWidth": 1,
      "showCrossLines": true,
      "guideCharacter": "{{character}}",
      "guideOpacity": 0.12,
      "guideFillRows": 1,
      "guideFontSize": 22
    },
    {
      "id": "triple_meta",
      "type": "text",
      "x": 64,
      "y": 48,
      "width": 124,
      "height": 6,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "content": "Bộ: {{radical}} · {{stroke_count}} nét · Bài {{_index}}",
      "fontSize": 8,
      "fontFamily": "Noto Sans SC",
      "fontWeight": "500",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#7c5b31",
      "backgroundColor": "transparent",
      "textAlign": "left",
      "lineHeight": 1.2
    }
  ]
}