{
  "version": 1,
  "pageSize": "A4",
  "name": "Classroom Standard",
  "description": "4 chữ/trang kiểu worksheet trường học: pinyin + chữ mẫu + stroke progression + hàng ô 田字格.",
  "recommendedItemsPerPage": 4,
  "elements": [
    {
      "id": "cls_header",
      "type": "text",
      "x": 10,
      "y": 4,
      "width": 190,
      "height": 7,
      "rotation": 0,
      "zIndex": 1,
      "locked": false,
      "content": "{{_index}}. {{character}} ({{pinyin}}) — {{vietnamese_meaning}}",
      "fontSize": 10,
      "fontFamily": "LXGW WenKai",
      "fontWeight": "bold",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#1a1a1a",
      "backgroundColor": "transparent",
      "textAlign": "left",
      "lineHeight": 1.2
    },
    {
      "id": "cls_char",
      "type": "hanziText",
      "x": 10,
      "y": 12,
      "width": 20,
      "height": 20,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "content": "{{character}}",
      "charSize": 24,
      "charGap": 0,
      "color": "#000000",
      "lineHeight": 1
    },
    {
      "id": "cls_stroke",
      "type": "strokeProgression",
      "x": 32,
      "y": 12,
      "width": 168,
      "height": 18,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "character": "{{character}}",
      "stepSize": 13,
      "stepGap": 0.3,
      "completedColor": "#333333",
      "activeColor": "#dc2626",
      "showStepNumbers": true,
      "numberFontSize": 5,
      "numberColor": "#999999",
      "showFullCharFirst": false,
      "fullCharColor": "#000000"
    },
    {
      "id": "cls_grid",
      "type": "practiceGrid",
      "x": 10,
      "y": 32,
      "width": 190,
      "height": 36,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "rows": 3,
      "cols": 14,
      "cellSize": 12,
      "borderColor": "#999999",
      "borderWidth": 1,
      "showCrossLines": true,
      "guideCharacter": "{{character}}",
      "guideOpacity": 0.1,
      "guideFillRows": 1,
      "guideFontSize": 22
    }
  ]
}