{
  "version": 1,
  "pageSize": "A4",
  "name": "Minimal Focus Template",
  "description": "Clean, simple one-character worksheet.",
  "recommendedItemsPerPage": 1,
  "elements": [
    {
      "id": "minimal_title",
      "type": "divider",
      "x": 18,
      "y": 18,
      "width": 174,
      "height": 12,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "label": "Bài {{_index}} · HSK {{hsk_level}}",
      "lineColor": "#94a3b8",
      "lineWidth": 1,
      "lineStyle": "solid",
      "ornament": "none",
      "fontSize": 10,
      "color": "#334155"
    },
    {
      "id": "minimal_character",
      "type": "text",
      "x": 58,
      "y": 38,
      "width": 94,
      "height": 76,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "content": "{{character}}",
      "fontSize": 118,
      "fontFamily": "Noto Serif SC",
      "fontWeight": "900",
      "fontStyle": "normal",
      "textDecoration": "none",
      "color": "#0f172a",
      "backgroundColor": "transparent",
      "textAlign": "center",
      "lineHeight": 1
    },
    {
      "id": "minimal_info",
      "type": "table",
      "x": 28,
      "y": 126,
      "width": 154,
      "height": 34,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "tableRows": 2,
      "tableCols": 3,
      "tableData": [
        ["Pinyin", "Hán Việt", "Nghĩa"],
        ["{{pinyin}}", "{{han_viet}}", "{{meaning_vi}}"]
      ],
      "headerBg": "#f1f5f9",
      "borderColor": "#cbd5e1",
      "cellPadding": 2,
      "fontSize": 10,
      "fontFamily": "Noto Sans SC",
      "fontColor": "#0f172a",
      "cellBg": "#ffffff",
      "autoHeight": false
    },
    {
      "id": "minimal_grid",
      "type": "practiceGrid",
      "x": 22,
      "y": 178,
      "width": 166,
      "height": 62,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "rows": 4,
      "cols": 12,
      "cellSize": 13,
      "borderColor": "#94a3b8",
      "borderWidth": 1,
      "showCrossLines": true,
      "guideCharacter": "{{character}}",
      "guideOpacity": 0.1,
      "guideFillRows": 1,
      "guideFontSize": 28
    },
    {
      "id": "minimal_example",
      "type": "callout",
      "x": 28,
      "y": 252,
      "width": 154,
      "height": 26,
      "rotation": 0,
      "zIndex": 2,
      "locked": false,
      "title": "Ví dụ",
      "body": "{{example_word}} · {{example_pinyin}} — {{example_meaning}}",
      "icon": "例",
      "accentColor": "#475569",
      "backgroundColor": "#f8fafc",
      "borderColor": "#cbd5e1",
      "fontSize": 9,
      "fontFamily": "Noto Sans SC",
      "color": "#334155",
      "borderRadius": 8
    }
  ]
}